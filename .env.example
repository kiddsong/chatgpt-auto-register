# ChatGPT 自动注册机配置文件
# 复制此文件为 .env 并填入你的配置

# ============================================================
# 临时邮箱服务配置（必需）
# ============================================================
# 邮箱服务域名和端口
WORKER_DOMAIN=your-mail-service.com:9000

# 邮箱服务 API Token
FREEMAIL_TOKEN=your_freemail_api_token_here

# ============================================================
# 代理配置（可选但强烈推荐）
# ============================================================
# SOCKS5 代理地址，格式：socks5://host:port
# 如果不使用代理，请注释掉或删除此行
PROXY_URL=socks5://127.0.0.1:10808
